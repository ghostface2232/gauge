<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Gauge.Views.PopoverWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:conv="using:Gauge.Converters"
    xmlns:loc="using:Gauge.Localization"
    mc:Ignorable="d">

    <!-- RootHost is transparent so the DesktopAcrylic backdrop shows through. Its
         tree-level KeyboardAccelerator handles ESC without making the full-window
         Grid a focus target. It is the element we slide + fade on show. RootBorder
         is where we round corners if we ever
         switch from DWM rounding to the transparent-window + inner-border approach. -->
    <Grid x:Name="RootHost" Background="Transparent" KeyboardAcceleratorPlacementMode="Hidden">
        <Grid.Resources>
          <ResourceDictionary>
            <!-- Hover/press overlay for borderless icon buttons. Stronger than the
                 system default so the affordance is clearly visible: a soft darken in
                 light theme, a soft lighten in dark theme. -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="IconButtonHoverBrush" Color="#0D000000" />
                    <SolidColorBrush x:Key="IconButtonPressedBrush" Color="#1A000000" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="IconButtonHoverBrush" Color="#1FFFFFFF" />
                    <SolidColorBrush x:Key="IconButtonPressedBrush" Color="#33FFFFFF" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <conv:UsageLevelToBrushConverter x:Key="LevelToBrush" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:PercentToGridLengthConverter x:Key="PercentToGridLength" />
            <conv:EmptyStringToNullConverter x:Key="EmptyToNull" />
            <Style x:Key="BorderlessIconButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="8" />
                <Setter Property="MinWidth" Value="32" />
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="RootGrid"
                                  Background="{TemplateBinding Background}"
                                  CornerRadius="{TemplateBinding CornerRadius}"
                                  Padding="{TemplateBinding Padding}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid"
                                                                               Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0"
                                                        Value="{ThemeResource IconButtonHoverBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootGrid"
                                                                               Storyboard.TargetProperty="Background">
                                                    <DiscreteObjectKeyFrame KeyTime="0"
                                                        Value="{ThemeResource IconButtonPressedBrush}" />
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="ContentPresenter"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.4" Duration="0" />
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter x:Name="ContentPresenter"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  Foreground="{TemplateBinding Foreground}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Compact account card. Header carries the tool name and a disconnect
                 (remove) button; the body shows the CLI login button for Claude/Codex
                 or sign-in guidance for app-login tools (Antigravity/Cursor). -->
            <DataTemplate x:Key="AuthCardTemplate">
                <Border Padding="12" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <Grid ColumnSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding ToolName}" TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <Button Grid.Column="1" Style="{StaticResource BorderlessIconButtonStyle}"
                                    MinWidth="28" MinHeight="28" Padding="6"
                                    Command="{Binding RemoveCommand}" ToolTipService.ToolTip="{loc:Localize Key=Tooltip_Disconnect}">
                                <FontIcon Glyph="&#xE711;" FontSize="12" />
                            </Button>
                        </Grid>
                        <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Opacity="0.75"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                        <Button Content="{Binding LoginButtonText}" Command="{Binding LoginCommand}"
                                HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                                Visibility="{Binding SupportsCliLogin, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </Border>
            </DataTemplate>
          </ResourceDictionary>
        </Grid.Resources>
        <Grid.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" />
        </Grid.RenderTransform>
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Escape" Invoked="OnEscapeInvoked" />
        </Grid.KeyboardAccelerators>

        <!-- Usage view. RootBorder spans the window edges; padding is applied per
             region so the footer can be a full-bleed bottom bar (Win11 Start-menu
             style). DWM rounds the window's outer corners. -->
        <Border x:Name="RootBorder" VerticalAlignment="Stretch">
            <Border.RenderTransform>
                <TranslateTransform x:Name="UsageViewTransform" />
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Fill the arranged client height so the window's small DPI
                         safety allowance is absorbed by the body. This keeps this
                         footer on the same bottom edge as the settings footer. -->
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Body: cards when there is data, otherwise a guidance message.
                     Padded region; BodyScroll caps its height in code so the window
                     never exceeds MaxPopoverHeightDip — taller content scrolls here.
                     No bottom padding so scrolling content clips flush at the footer
                     divider instead of vanishing into an empty band above it. -->
                <Border Grid.Row="0" Padding="16,16,16,0">
                <Grid>
                <!-- Centered guidance shown when no tool has any data. -->
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    TextAlignment="Center"
                    TextWrapping="Wrap"
                    Opacity="0.7"
                    Text="{Binding EmptyMessage}"
                    Style="{StaticResource BodyTextBlockStyle}"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />
                <ScrollViewer
                    x:Name="BodyScroll"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Disabled"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                    <!-- Bottom margin scrolls with the content. Together with the last
                         card's 8dip margin and the 4dip window-height safety allowance
                         absorbed by this row, it matches the 16dip top spacing. -->
                    <ItemsControl ItemsSource="{Binding Cards}" Margin="0,0,0,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,8"
                                    Padding="14"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <StackPanel Spacing="10">
                                        <!-- Tool name + plan tier (lighter, e.g. "Max 5x" / "Plus"). -->
                                        <StackPanel
                                            Orientation="Horizontal"
                                            Margin="0,0,0,4"
                                            Spacing="6">
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Text="{Binding ToolName}"
                                                Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Opacity="0.5"
                                                FontSize="14"
                                                Text="{Binding Plan}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Visibility="{Binding HasPlan, Converter={StaticResource BoolToVis}}" />
                                        </StackPanel>

                                        <!-- One row per window the tool has (5시간 / 주간). -->
                                        <ItemsControl
                                            ItemsSource="{Binding Windows}"
                                            Visibility="{Binding HasAnyData, Converter={StaticResource BoolToVis}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Spacing="2" Margin="0,0,0,10">
                                                        <Grid ColumnSpacing="10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock
                                                                Grid.Column="0"
                                                                MinWidth="44"
                                                                VerticalAlignment="Center"
                                                                Opacity="0.8"
                                                                Text="{Binding Label}"
                                                                Style="{StaticResource CaptionTextBlockStyle}" />
                                                            <!-- Custom progress bar: rounded track with a rounded fill sized by
                                                                 percent. Thicker and clearly a progress bar (not the thin,
                                                                 slider-like default). Height/CornerRadius easy to tune. -->
                                                            <Border
                                                                Grid.Column="1"
                                                                Height="8"
                                                                VerticalAlignment="Center"
                                                                CornerRadius="4"
                                                                Background="{ThemeResource ControlAltFillColorTertiaryBrush}">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="{Binding Percent, Converter={StaticResource PercentToGridLength}}" />
                                                                        <ColumnDefinition Width="{Binding Percent, Converter={StaticResource PercentToGridLength}, ConverterParameter=rest}" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border
                                                                        Grid.Column="0"
                                                                        CornerRadius="4"
                                                                        Background="{Binding Level, Converter={StaticResource LevelToBrush}}" />
                                                                </Grid>
                                                            </Border>
                                                            <!-- Always show the number, not color alone (accessibility). -->
                                                            <TextBlock
                                                                Grid.Column="2"
                                                                MinWidth="40"
                                                                TextAlignment="Right"
                                                                VerticalAlignment="Center"
                                                                Text="{Binding PercentText}"
                                                                Style="{StaticResource BodyStrongTextBlockStyle}" />
                                                        </Grid>
                                                        <TextBlock
                                                            Margin="54,0,0,0"
                                                            Opacity="0.7"
                                                            Text="{Binding ResetText}"
                                                            Style="{StaticResource CaptionTextBlockStyle}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- No windows for this tool at all. -->
                                        <TextBlock
                                            Text="{Binding StatusText}"
                                            Opacity="0.6"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Visibility="{Binding HasAnyData, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                </Grid>
                </Border>

                <!-- Footer bar: full-bleed strip with a top divider, mildly more opaque
                     than the acrylic body — like the Windows 11 Start menu bottom bar.
                     MinHeight + padding kept identical to the settings bar for a
                     consistent footer across both views. -->
                <Border Grid.Row="1"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0"
                        Height="52"
                        Padding="16,9">
                    <Grid ColumnSpacing="6" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Opacity="0.7"
                            Text="{Binding LastUpdatedText}"
                            Style="{StaticResource CaptionTextBlockStyle}" />
                        <Button
                            Grid.Column="1"
                            Style="{StaticResource BorderlessIconButtonStyle}"
                            Padding="8,9"
                            Command="{Binding RefreshCommand}"
                            ToolTipService.ToolTip="{loc:Localize Key=Tooltip_Refresh}">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        </Button>
                        <Button
                            Grid.Column="2"
                            Style="{StaticResource BorderlessIconButtonStyle}"
                            Padding="8,9"
                            Click="OnSettingsClicked"
                            ToolTipService.ToolTip="{loc:Localize Key=Settings}">
                            <FontIcon Glyph="&#xE713;" FontSize="14" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Settings is a second view inside the same acrylic popover. Stretches so
             the update row can sit at the bottom (the window keeps the usage view's
             height while settings is shown). -->
        <Border x:Name="SettingsBorder" VerticalAlignment="Stretch" Visibility="Collapsed">
            <Border.RenderTransform>
                <TranslateTransform x:Name="SettingsViewTransform" />
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header stays fixed; only the service list scrolls. -->
                <Border Grid.Row="0" Padding="16,16,16,8">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource BorderlessIconButtonStyle}"
                                Click="OnSettingsBackClicked" ToolTipService.ToolTip="{loc:Localize Key=Tooltip_Back}">
                            <FontIcon Glyph="&#xE72B;" FontSize="14" />
                        </Button>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{loc:Localize Key=Settings}"
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                    </Grid>
                </Border>

                <!-- Scrollable content: global toggles, then the service list. No
                     ScrollViewer bottom padding; the inner StackPanel carries a 12dip
                     bottom margin instead so the gap above the update bar at full scroll
                     matches the usage view's (its last card's 8dip + list's 4dip). The
                     list grows to a scroll as more services are registered or on a short
                     window — VerticalScrollBarVisibility=Auto turns the scrollbar on only
                     when the content actually exceeds the (usage-matched) panel height. -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollMode="Disabled" Padding="16,0,16,0">
                <StackPanel Spacing="14" VerticalAlignment="Top" Margin="0,0,0,12">
                    <!-- App-wide toggles, grouped in one card directly under the title:
                         usage notifications and run-on-startup. Two-way bound to the
                         GlobalSettingsViewModel; the empty On/Off content keeps the switch
                         compact and language-neutral. -->
                    <Border CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            Padding="14,2">
                        <StackPanel>
                            <Grid MinHeight="48" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="1">
                                    <TextBlock Text="{loc:Localize Key=Settings_Notifications}"
                                               Style="{StaticResource BodyTextBlockStyle}" />
                                    <TextBlock Text="{loc:Localize Key=Settings_NotificationsDesc}"
                                               Opacity="0.6" TextWrapping="Wrap"
                                               Style="{StaticResource CaptionTextBlockStyle}" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" VerticalAlignment="Center"
                                              MinWidth="0" OnContent="" OffContent=""
                                              IsOn="{Binding Global.NotificationsEnabled, Mode=TwoWay}" />
                            </Grid>
                            <Border Height="1" Margin="0,2"
                                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                            <Grid MinHeight="48" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="1">
                                    <TextBlock Text="{loc:Localize Key=Settings_StartOnBoot}"
                                               Style="{StaticResource BodyTextBlockStyle}" />
                                    <TextBlock Text="{loc:Localize Key=Settings_StartOnBootDesc}"
                                               Opacity="0.6" TextWrapping="Wrap"
                                               Style="{StaticResource CaptionTextBlockStyle}" />
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" VerticalAlignment="Center"
                                              MinWidth="0" OnContent="" OffContent=""
                                              IsOn="{Binding Global.StartOnBoot, Mode=TwoWay}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- One card per tool, side by side at equal width and height.
                         Data-bound (not indexed) so adding a tool needs no XAML change. -->
                    <ItemsRepeater ItemsSource="{Binding Authentication}"
                                   ItemTemplate="{StaticResource AuthCardTemplate}">
                        <ItemsRepeater.Layout>
                            <!-- MinItemWidth lets two cards share the ~328dip content width
                                 (8dip gap); ItemsStretch=Fill then stretches them to equal width. -->
                            <UniformGridLayout MinItemWidth="120" MinColumnSpacing="8" MinRowSpacing="8" ItemsStretch="Fill" />
                        </ItemsRepeater.Layout>
                    </ItemsRepeater>
                </StackPanel>
                </ScrollViewer>

                <!-- Bottom bar: version on the left, update action on the right. Same
                     full-bleed divider treatment, MinHeight and padding as the usage
                     view's footer so both views share an identical bottom bar. -->
                <Border Grid.Row="2"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0"
                        Height="52"
                        Padding="16,9"
                        DataContext="{Binding Update}">
                    <Grid ColumnSpacing="6" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Opacity="0.7"
                                   Text="{Binding VersionText}"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                        <!-- Entry point to connect another service. A flyout (built in code
                             from the registry's available tools) picks which one to add.
                             Icon-only to match the header's borderless buttons; label is in the tooltip. -->
                        <Button x:Name="AddServiceButton" Grid.Column="1"
                                Style="{StaticResource BorderlessIconButtonStyle}"
                                Padding="8,9" VerticalAlignment="Center"
                                Click="OnAddServiceClicked"
                                ToolTipService.ToolTip="{loc:Localize Key=AddService}">
                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                        </Button>
                        <!-- Update action: Sync glyph while checking, Download once a release is found.
                             Status/label surfaced on hover via the tooltip. -->
                        <Button Grid.Column="2"
                                Style="{StaticResource BorderlessIconButtonStyle}"
                                Padding="8,9" VerticalAlignment="Center"
                                Command="{Binding ActionCommand}"
                                ToolTipService.ToolTip="{Binding Tooltip}">
                            <FontIcon Glyph="{Binding ActionGlyph}" FontSize="14" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>
