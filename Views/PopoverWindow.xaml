<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Gauge.Views.PopoverWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:conv="using:Gauge.Converters"
    mc:Ignorable="d">

    <!-- RootHost is transparent so the DesktopAcrylic backdrop shows through. Its
         tree-level KeyboardAccelerator handles ESC without making the full-window
         Grid a focus target. It is the element we slide + fade on show. RootBorder
         is where we round corners if we ever
         switch from DWM rounding to the transparent-window + inner-border approach. -->
    <Grid x:Name="RootHost" Background="Transparent" KeyboardAcceleratorPlacementMode="Hidden">
        <Grid.Resources>
            <conv:UsageLevelToBrushConverter x:Key="LevelToBrush" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:PercentToGridLengthConverter x:Key="PercentToGridLength" />
            <conv:EmptyStringToNullConverter x:Key="EmptyToNull" />
            <Style x:Key="BorderlessIconButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="8" />
                <Setter Property="MinWidth" Value="32" />
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="CornerRadius" Value="4" />
            </Style>

            <!-- Compact account card. Header carries the tool name and a disconnect
                 (remove) button; the body shows the CLI login button for Claude/Codex
                 or sign-in guidance for app-login tools (Antigravity/Cursor). -->
            <DataTemplate x:Key="AuthCardTemplate">
                <Border Padding="12" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <Grid ColumnSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding ToolName}" TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <Button Grid.Column="1" Style="{StaticResource BorderlessIconButtonStyle}"
                                    MinWidth="28" MinHeight="28" Padding="6"
                                    Command="{Binding RemoveCommand}" ToolTipService.ToolTip="연결 해제">
                                <FontIcon Glyph="&#xE711;" FontSize="12" />
                            </Button>
                        </Grid>
                        <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Opacity="0.75"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                        <Button Content="{Binding LoginButtonText}" Command="{Binding LoginCommand}"
                                HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                                Visibility="{Binding SupportsCliLogin, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </Border>
            </DataTemplate>
        </Grid.Resources>
        <Grid.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" />
        </Grid.RenderTransform>
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Escape" Invoked="OnEscapeInvoked" />
        </Grid.KeyboardAccelerators>

        <!-- Usage view. RootBorder spans the window edges; padding is applied per
             region so the footer can be a full-bleed bottom bar (Win11 Start-menu
             style). DWM rounds the window's outer corners. -->
        <Border x:Name="RootBorder" VerticalAlignment="Stretch">
            <Border.RenderTransform>
                <TranslateTransform x:Name="UsageViewTransform" />
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Fill the arranged client height so the window's small DPI
                         safety allowance is absorbed by the body. This keeps this
                         footer on the same bottom edge as the settings footer. -->
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Body: cards when there is data, otherwise a guidance message.
                     Padded region; BodyScroll caps its height in code so the window
                     never exceeds MaxPopoverHeightDip — taller content scrolls here.
                     No bottom padding so scrolling content clips flush at the footer
                     divider instead of vanishing into an empty band above it. -->
                <Border Grid.Row="0" Padding="16,16,16,0">
                <Grid>
                <!-- Centered guidance shown when no tool has any data. -->
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    TextAlignment="Center"
                    TextWrapping="Wrap"
                    Opacity="0.7"
                    Text="{Binding EmptyMessage}"
                    Style="{StaticResource BodyTextBlockStyle}"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />
                <ScrollViewer
                    x:Name="BodyScroll"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Disabled"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                    <!-- Bottom margin scrolls with the content. Together with the last
                         card's 8dip margin and the 4dip window-height safety allowance
                         absorbed by this row, it matches the 16dip top spacing. -->
                    <ItemsControl ItemsSource="{Binding Cards}" Margin="0,0,0,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,8"
                                    Padding="14"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <StackPanel Spacing="10">
                                        <!-- Tool name + plan tier (lighter, e.g. "Max 5x" / "Plus"). -->
                                        <StackPanel
                                            Orientation="Horizontal"
                                            Margin="0,0,0,4"
                                            Spacing="6">
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Text="{Binding ToolName}"
                                                Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Opacity="0.5"
                                                Text="{Binding Plan}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Visibility="{Binding HasPlan, Converter={StaticResource BoolToVis}}" />
                                        </StackPanel>

                                        <!-- One row per window the tool has (5시간 / 주간). -->
                                        <ItemsControl
                                            ItemsSource="{Binding Windows}"
                                            Visibility="{Binding HasAnyData, Converter={StaticResource BoolToVis}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Spacing="2" Margin="0,0,0,10">
                                                        <Grid ColumnSpacing="10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock
                                                                Grid.Column="0"
                                                                MinWidth="44"
                                                                VerticalAlignment="Center"
                                                                Opacity="0.8"
                                                                Text="{Binding Label}"
                                                                Style="{StaticResource CaptionTextBlockStyle}" />
                                                            <!-- Custom progress bar: rounded track with a rounded fill sized by
                                                                 percent. Thicker and clearly a progress bar (not the thin,
                                                                 slider-like default). Height/CornerRadius easy to tune. -->
                                                            <Border
                                                                Grid.Column="1"
                                                                Height="8"
                                                                VerticalAlignment="Center"
                                                                CornerRadius="4"
                                                                Background="{ThemeResource ControlAltFillColorTertiaryBrush}">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="{Binding Percent, Converter={StaticResource PercentToGridLength}}" />
                                                                        <ColumnDefinition Width="{Binding Percent, Converter={StaticResource PercentToGridLength}, ConverterParameter=rest}" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border
                                                                        Grid.Column="0"
                                                                        CornerRadius="4"
                                                                        Background="{Binding Level, Converter={StaticResource LevelToBrush}}" />
                                                                </Grid>
                                                            </Border>
                                                            <!-- Always show the number, not color alone (accessibility). -->
                                                            <TextBlock
                                                                Grid.Column="2"
                                                                MinWidth="40"
                                                                TextAlignment="Right"
                                                                VerticalAlignment="Center"
                                                                Text="{Binding PercentText}"
                                                                Style="{StaticResource BodyStrongTextBlockStyle}" />
                                                        </Grid>
                                                        <TextBlock
                                                            Margin="54,0,0,0"
                                                            Opacity="0.7"
                                                            Text="{Binding ResetText}"
                                                            Style="{StaticResource CaptionTextBlockStyle}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- No windows for this tool at all. -->
                                        <TextBlock
                                            Text="{Binding StatusText}"
                                            Opacity="0.6"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Visibility="{Binding HasAnyData, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                </Grid>
                </Border>

                <!-- Footer bar: full-bleed strip with a top divider, mildly more opaque
                     than the acrylic body — like the Windows 11 Start menu bottom bar.
                     MinHeight + padding kept identical to the settings bar for a
                     consistent footer across both views. -->
                <Border Grid.Row="1"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0"
                        Height="52"
                        Padding="16,9">
                    <Grid ColumnSpacing="6" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Opacity="0.7"
                            Text="{Binding LastUpdatedText}"
                            Style="{StaticResource CaptionTextBlockStyle}" />
                        <Button
                            Grid.Column="1"
                            Style="{StaticResource BorderlessIconButtonStyle}"
                            Padding="8,9"
                            Command="{Binding RefreshCommand}"
                            ToolTipService.ToolTip="새로고침">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        </Button>
                        <Button
                            Grid.Column="2"
                            Style="{StaticResource BorderlessIconButtonStyle}"
                            Padding="8,9"
                            Click="OnSettingsClicked"
                            ToolTipService.ToolTip="설정">
                            <FontIcon Glyph="&#xE713;" FontSize="14" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Settings is a second view inside the same acrylic popover. Stretches so
             the update row can sit at the bottom (the window keeps the usage view's
             height while settings is shown). -->
        <Border x:Name="SettingsBorder" VerticalAlignment="Stretch" Visibility="Collapsed">
            <Border.RenderTransform>
                <TranslateTransform x:Name="SettingsViewTransform" />
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header stays fixed; only the service list scrolls. -->
                <Border Grid.Row="0" Padding="16,16,16,8">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource BorderlessIconButtonStyle}"
                                Click="OnSettingsBackClicked" ToolTipService.ToolTip="뒤로">
                            <FontIcon Glyph="&#xE72B;" FontSize="14" />
                        </Button>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="설정"
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                    </Grid>
                </Border>

                <!-- Scrollable service list. No bottom padding so it clips flush at the
                     update bar, mirroring the usage view. Grows to a scroll as more
                     services are registered. -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollMode="Disabled" Padding="16,0,16,0">
                <StackPanel Spacing="14" VerticalAlignment="Top">
                    <!-- One card per tool, side by side at equal width and height.
                         Data-bound (not indexed) so adding a tool needs no XAML change. -->
                    <ItemsRepeater ItemsSource="{Binding Authentication}"
                                   ItemTemplate="{StaticResource AuthCardTemplate}">
                        <ItemsRepeater.Layout>
                            <!-- MinItemWidth lets two cards share the ~328dip content width
                                 (8dip gap); ItemsStretch=Fill then stretches them to equal width. -->
                            <UniformGridLayout MinItemWidth="120" MinColumnSpacing="8" MinRowSpacing="8" ItemsStretch="Fill" />
                        </ItemsRepeater.Layout>
                    </ItemsRepeater>

                    <!-- Entry point to connect another service. A flyout (built in code
                         from the registry's available tools) picks which one to add. -->
                    <Button x:Name="AddServiceButton" Click="OnAddServiceClicked"
                            HorizontalAlignment="Stretch" Padding="12,10" CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                            <TextBlock Text="서비스 추가" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                </ScrollViewer>

                <!-- Bottom bar: version on the left, update action on the right. Same
                     full-bleed divider treatment, MinHeight and padding as the usage
                     view's footer so both views share an identical bottom bar. -->
                <Border Grid.Row="2"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0"
                        Height="52"
                        Padding="16,9"
                        DataContext="{Binding Update}">
                    <Grid ColumnSpacing="6" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Opacity="0.7"
                                   Text="{Binding VersionText}"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                        <Button Grid.Column="1" Content="{Binding ActionButtonText}"
                                Command="{Binding ActionCommand}"
                                Height="32" Padding="12,4" VerticalAlignment="Center"
                                ToolTipService.ToolTip="{Binding StatusText, Converter={StaticResource EmptyToNull}}" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>
