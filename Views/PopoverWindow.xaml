<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Gauge.Views.PopoverWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:conv="using:Gauge.Converters"
    mc:Ignorable="d">

    <!-- RootHost is transparent so the DesktopAcrylic backdrop shows through. Its
         tree-level KeyboardAccelerator handles ESC without making the full-window
         Grid a focus target. It is the element we slide + fade on show. RootBorder
         is where we round corners if we ever
         switch from DWM rounding to the transparent-window + inner-border approach. -->
    <Grid x:Name="RootHost" Background="Transparent">
        <Grid.Resources>
            <conv:UsageLevelToBrushConverter x:Key="LevelToBrush" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:PercentToGridLengthConverter x:Key="PercentToGridLength" />
            <Style x:Key="BorderlessIconButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="8" />
                <Setter Property="MinWidth" Value="32" />
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="CornerRadius" Value="4" />
            </Style>

            <!-- Compact account card; rendered two-up (Claude Code / Codex) so the
                 settings view stays short enough for the update card below. -->
            <DataTemplate x:Key="AuthCardTemplate">
                <Border Padding="12" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding ToolName}" TextWrapping="Wrap"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Opacity="0.75"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                        <Button Content="{Binding LoginButtonText}" Command="{Binding LoginCommand}"
                                HorizontalAlignment="Stretch" VerticalAlignment="Bottom" />
                    </StackPanel>
                </Border>
            </DataTemplate>
        </Grid.Resources>
        <Grid.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" />
        </Grid.RenderTransform>
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Escape" Invoked="OnEscapeInvoked" />
        </Grid.KeyboardAccelerators>

        <!-- Generous Quick-Settings-like padding/spacing; exact values are easy to tune. -->
        <!-- Top-aligned so the border sizes to its content; the window height is then
             matched to it in code (no bottom filler). -->
        <Border x:Name="RootBorder" Padding="16" VerticalAlignment="Top">
            <Border.RenderTransform>
                <TranslateTransform x:Name="UsageViewTransform" />
            </Border.RenderTransform>
            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Body: cards when there is data, otherwise a guidance message. -->
                <Grid Grid.Row="0">
                <!-- Centered guidance shown when no tool has any data. -->
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    TextAlignment="Center"
                    TextWrapping="Wrap"
                    Opacity="0.7"
                    Text="{Binding EmptyMessage}"
                    Style="{StaticResource BodyTextBlockStyle}"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />
                <ScrollViewer
                    x:Name="BodyScroll"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Disabled"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                    <ItemsControl ItemsSource="{Binding Cards}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,0,8"
                                    Padding="14"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <StackPanel Spacing="10">
                                        <!-- Tool name + plan tier (lighter, e.g. "Max 5x" / "Plus"). -->
                                        <StackPanel
                                            Orientation="Horizontal"
                                            Margin="0,0,0,4"
                                            Spacing="6">
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Text="{Binding ToolName}"
                                                Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Opacity="0.5"
                                                Text="{Binding Plan}"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Visibility="{Binding HasPlan, Converter={StaticResource BoolToVis}}" />
                                        </StackPanel>

                                        <!-- One row per window the tool has (5시간 / 주간). -->
                                        <ItemsControl
                                            ItemsSource="{Binding Windows}"
                                            Visibility="{Binding HasAnyData, Converter={StaticResource BoolToVis}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Spacing="2" Margin="0,0,0,10">
                                                        <Grid ColumnSpacing="10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock
                                                                Grid.Column="0"
                                                                MinWidth="44"
                                                                VerticalAlignment="Center"
                                                                Opacity="0.8"
                                                                Text="{Binding Label}"
                                                                Style="{StaticResource CaptionTextBlockStyle}" />
                                                            <!-- Custom progress bar: rounded track with a rounded fill sized by
                                                                 percent. Thicker and clearly a progress bar (not the thin,
                                                                 slider-like default). Height/CornerRadius easy to tune. -->
                                                            <Border
                                                                Grid.Column="1"
                                                                Height="8"
                                                                VerticalAlignment="Center"
                                                                CornerRadius="4"
                                                                Background="{ThemeResource ControlAltFillColorTertiaryBrush}">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="{Binding Percent, Converter={StaticResource PercentToGridLength}}" />
                                                                        <ColumnDefinition Width="{Binding Percent, Converter={StaticResource PercentToGridLength}, ConverterParameter=rest}" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border
                                                                        Grid.Column="0"
                                                                        CornerRadius="4"
                                                                        Background="{Binding Level, Converter={StaticResource LevelToBrush}}" />
                                                                </Grid>
                                                            </Border>
                                                            <!-- Always show the number, not color alone (accessibility). -->
                                                            <TextBlock
                                                                Grid.Column="2"
                                                                MinWidth="40"
                                                                TextAlignment="Right"
                                                                VerticalAlignment="Center"
                                                                Text="{Binding PercentText}"
                                                                Style="{StaticResource BodyStrongTextBlockStyle}" />
                                                        </Grid>
                                                        <TextBlock
                                                            Margin="54,0,0,0"
                                                            Opacity="0.7"
                                                            Text="{Binding ResetText}"
                                                            Style="{StaticResource CaptionTextBlockStyle}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- No windows for this tool at all. -->
                                        <TextBlock
                                            Text="{Binding StatusText}"
                                            Opacity="0.6"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Visibility="{Binding HasAnyData, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                </Grid>

                <!-- Footer: last-updated, manual refresh, settings gear placeholder. -->
                <Grid Grid.Row="1" ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Opacity="0.7"
                        Text="{Binding LastUpdatedText}"
                        Style="{StaticResource CaptionTextBlockStyle}" />
                    <Button
                        Grid.Column="1"
                        Style="{StaticResource BorderlessIconButtonStyle}"
                        Command="{Binding RefreshCommand}"
                        ToolTipService.ToolTip="새로고침">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    </Button>
                    <!-- Settings placeholder; wired in a later step. -->
                    <Button
                        Grid.Column="2"
                        Style="{StaticResource BorderlessIconButtonStyle}"
                        Click="OnSettingsClicked"
                        ToolTipService.ToolTip="설정">
                        <FontIcon Glyph="&#xE713;" FontSize="14" />
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- Settings is a second view inside the same acrylic popover. -->
        <Border x:Name="SettingsBorder" Padding="16" VerticalAlignment="Top" Visibility="Collapsed">
            <Border.RenderTransform>
                <TranslateTransform x:Name="SettingsViewTransform" />
            </Border.RenderTransform>
            <StackPanel Spacing="14">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource BorderlessIconButtonStyle}"
                            Click="OnSettingsBackClicked" ToolTipService.ToolTip="뒤로">
                        <FontIcon Glyph="&#xE72B;" FontSize="14" />
                    </Button>
                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="설정"
                               Style="{StaticResource SubtitleTextBlockStyle}" />
                </Grid>

                <!-- Two accounts side by side, equal width and height. -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ContentControl Grid.Column="0" Content="{Binding Authentication[0]}"
                                    ContentTemplate="{StaticResource AuthCardTemplate}"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
                    <ContentControl Grid.Column="1" Content="{Binding Authentication[1]}"
                                    ContentTemplate="{StaticResource AuthCardTemplate}"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
                </Grid>

                <!-- Update card: label and buttons share one row; buttons right-aligned. -->
                <Border Padding="14" CornerRadius="8" DataContext="{Binding Update}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="10">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="업데이트" VerticalAlignment="Center"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                        HorizontalAlignment="Right">
                                <Button Content="업데이트 확인" Command="{Binding CheckCommand}" />
                                <Button Content="지금 업데이트" Style="{StaticResource AccentButtonStyle}"
                                        Command="{Binding UpdateCommand}"
                                        Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="{Binding CurrentVersionText}" Opacity="0.75"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Opacity="0.75"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

    </Grid>
</Window>
