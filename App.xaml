<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Gauge.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- H.NotifyIcon's SecondWindow mode clones the supplied MenuFlyout but does
                 not copy MenuFlyoutPresenterStyle. Keep this implicit so it reaches the
                 presenter created for the actual clone. The host size is corrected in
                 TrayIconService; disabling scroll is a final guard for this fixed menu. -->
            <Style TargetType="MenuFlyoutPresenter"
                   BasedOn="{StaticResource DefaultMenuFlyoutPresenterStyle}">
                <Setter Property="ScrollViewer.VerticalScrollMode" Value="Disabled" />
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
                <Setter Property="ScrollViewer.HorizontalScrollMode" Value="Disabled" />
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            </Style>

            <!-- Usage-level colors as named resources (never hardcoded inline at the
                 use site). Chosen to read on both light/dark acrylic; if per-theme
                 tuning is wanted later, move these into ResourceDictionary.ThemeDictionaries. -->
            <SolidColorBrush x:Key="UsageOkBrush" Color="#2E9E4F" />
            <SolidColorBrush x:Key="UsageCautionBrush" Color="#FEAD0C" />
            <SolidColorBrush x:Key="UsageDangerBrush" Color="#FE140C" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
